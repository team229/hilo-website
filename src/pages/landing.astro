---
import BaseLayout from '../layouts/BaseLayout.astro';
import LandingForm from '../components/LandingForm';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import headerLogo from '../assets/header-logo.png';
import teamImg from '../assets/team.jpg';

const siteUrl = 'https://hiloheatingandair.com';
const phone = '(714) 853-5534';
const phoneHref = 'tel:+17148535534';

const landingFaqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question", "name": "Do you offer same-day AC repair in Orange County?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — HiLo dispatches same-day AC repair across Orange County, Anaheim, Irvine, Santa Ana, Fullerton, and more. Most calls are handled within hours. Call (714) 853-5534 for immediate dispatch." }
    },
    {
      "@type": "Question", "name": "Is the HVAC diagnostic fee really free?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — HiLo Heating & Air waives the standard diagnostic fee when you approve any repair. If you decide not to proceed, there is a small diagnostic charge." }
    },
    {
      "@type": "Question", "name": "Do you offer 24/7 emergency HVAC repair?",
      "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. HiLo offers 24/7 emergency HVAC repair across Orange County and Los Angeles. Call (714) 853-5534 anytime for immediate dispatch." }
    },
    {
      "@type": "Question", "name": "What areas do you serve for AC repair and HVAC service?",
      "acceptedAnswer": { "@type": "Answer", "text": "HiLo serves all of Orange County including Anaheim, Irvine, Santa Ana, Fullerton, Costa Mesa, Newport Beach, Garden Grove, Laguna Hills, Stanton, Rancho Santa Margarita, plus Los Angeles." }
    }
  ]
};

const features = [
  { text: 'Same-Day Service', icon: 'M12 6v6l4 2' },
  { text: '24/7 Emergency Repair', icon: 'M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z' },
  { text: 'EPA Certified Technicians', icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z' },
  { text: 'Free Diagnostic w/ Repair', icon: 'M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
  { text: 'Financing Available', icon: 'M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z' },
];

const services = [
  { icon: '❄️', title: 'Air Conditioning', slug: '/emergency-ac-repair/', features: ['Same-Day AC Repair', 'New Installation', 'Mini Splits'] },
  { icon: '🔥', title: 'Heating', slug: '/heating-repair/', features: ['Furnace Repair', 'Heater Installation', 'Emergency Heating'] },
  { icon: '⚙️', title: 'HVAC Maintenance', slug: '/ac-maintenance/', features: ['Seasonal Tune-Ups', 'Duct Sealing', 'Full Inspections'] },
  { icon: '🌿', title: 'Indoor Air Quality', slug: '/service/indoor-air-quality/', features: ['Air Purifiers', 'Humidifiers', 'Filtration Systems'] },
];

const reviews = [
  { name: 'Michael R.', initial: 'M', text: 'Fast response, honest pricing, and the technician fixed our AC the same day. Highly recommend.' },
  { name: 'Sarah T.', initial: 'S', text: 'Professional company that actually repairs before trying to replace everything.' },
  { name: 'Daniel K.', initial: 'D', text: 'Very responsive during an emergency HVAC issue. Great communication and clean installation.' },
];

const faqs = [
  { q: 'Do you offer same-day AC repair in Orange County?', a: 'Yes — we dispatch same-day across Orange County, Anaheim, Irvine, Santa Ana, and Fullerton. Most calls handled within hours.' },
  { q: 'Is the HVAC diagnostic fee really free?', a: '100% free when you approve any repair. If you decide not to proceed, there\'s a small diagnostic charge.' },
  { q: 'Can you handle emergency HVAC repairs after hours?', a: '24/7 emergency service. Call (714) 853-5534 anytime and we\'ll dispatch a technician immediately.' },
  { q: 'What areas do you serve for HVAC service?', a: 'All of Orange County — Anaheim, Irvine, Santa Ana, Fullerton, Costa Mesa, Newport Beach, Garden Grove, Laguna Hills, Stanton — plus Los Angeles.' },
];

const cities = [
  { name: 'Anaheim', slug: '/service-areas/anaheim/' },
  { name: 'Fullerton', slug: '/service-areas/fullerton/' },
  { name: 'Orange', slug: '/service-areas/orange/' },
  { name: 'Irvine', slug: '/service-areas/irvine/' },
  { name: 'Santa Ana', slug: '/service-areas/santa-ana/' },
  { name: 'Costa Mesa', slug: '/service-areas/costa-mesa/' },
  { name: 'Newport Beach', slug: '/service-areas/newport-beach/' },
  { name: 'Garden Grove', slug: '/service-areas/garden-grove/' },
  { name: 'Laguna Hills', slug: '/service-areas/laguna-hills/' },
  { name: 'Stanton', slug: '/service-areas/stanton/' },
  { name: 'Rancho Santa Margarita', slug: '/service-areas/rancho-santa-margarita/' },
  { name: 'Los Angeles', slug: '/service-areas/los-angeles/' },
];
---

<BaseLayout
  title="Same-Day AC Repair & HVAC Service in Orange County | HiLo Heating & Air"
  description="AC broken? Same-day AC repair, HVAC service & emergency dispatch in Orange County & LA. Techs dispatching now. Free estimates, no hidden fees. Call (714) 853-5534."
  canonical={`${siteUrl}/landing/`}
  robots="noindex, nofollow"
>
  <!-- === TOP URGENCY BAR (sticky) === -->
  <div class="sticky top-0 z-[99999] bg-brand-red text-white text-xs sm:text-sm font-bold shadow-lg shadow-black/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between py-2">
      <div class="flex items-center gap-3">
        <a href="/" class="flex-shrink-0">
          <Image src={headerLogo} alt="HiLo Heating & Air" class="h-12 w-auto drop-shadow-[0_2px_6px_rgba(0,0,0,0.35)] brightness-110" width={140} height={105} />
        </a>
        <span class="hidden sm:inline w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
        <span class="hidden sm:inline text-xs sm:text-sm font-bold">Techs Dispatching Now in Orange County & LA</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="hidden sm:inline bg-white/20 text-white text-xs font-extrabold uppercase tracking-wider px-3 py-1 rounded-full border border-white/30 shadow-sm">Same-Day Service</span>
        <a href={phoneHref} class="flex items-center gap-1.5 hover:underline font-extrabold">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {phone}
        </a>
      </div>
    </div>
  </div>

  <!-- === MAIN CONTENT === -->
  <main>
    <!-- ========== HERO ========== -->
    <section class="relative bg-gradient-to-br from-brand-blue via-[#054a9f] to-brand-blue overflow-hidden">
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 25% 50%, white 1px, transparent 1px); background-size: 30px 30px;"></div>
      <div class="absolute top-[-20%] right-[-10%] w-[60%] h-[80%] bg-brand-red/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-[-10%] left-[-5%] w-[40%] h-[50%] bg-white/5 rounded-full blur-3xl"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12 lg:py-14 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10 items-start">

          <!-- LEFT: Headline + Trust -->
          <div class="lg:col-span-7 flex flex-col space-y-5">
            <div class="flex items-center gap-2.5 bg-white/10 backdrop-blur-sm border border-white/15 px-4 py-2 rounded-full self-start">
              <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
              <span class="text-white/90 text-xs sm:text-sm font-bold tracking-wide uppercase">Family-Owned HVAC Company • Orange County • Since 2016</span>
            </div>

            <h1 class="text-[1.8rem] sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold tracking-tight leading-[1.1] text-white max-w-2xl">
              AC <span class="text-brand-red">Broken?</span><br />
              <span class="text-white/95">Same-Day AC Repair &amp; HVAC Service</span><br />
              <span class="text-brand-red">in Orange County.</span>
            </h1>

            <p class="text-base sm:text-lg text-white/80 max-w-xl font-medium leading-relaxed">
              <a href="#request-form" class="text-white underline hover:text-brand-red transition-colors">Same-day AC repair</a>, <a href="#request-form" class="text-white underline hover:text-brand-red transition-colors">heating service</a>, and <a href="#request-form" class="text-white underline hover:text-brand-red transition-colors">emergency HVAC dispatch</a> across Orange County &amp; LA — with upfront pricing and <strong class="text-white">no hidden fees</strong>.
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2.5 max-w-xl">
              {features.map((f) => (
                <div class="flex items-center gap-3 bg-white/10 backdrop-blur-sm rounded-xl px-4 py-3 border border-white/10">
                  <div class="w-6 h-6 rounded-full bg-green-500/20 flex items-center justify-center flex-shrink-0">
                    <svg class="w-3.5 h-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  </div>
                  <span class="text-xs sm:text-sm font-bold text-white/95">{f.text}</span>
                </div>
              ))}
            </div>

            <!-- CTA Buttons -->
            <div class="flex flex-col sm:flex-row gap-3.5 pt-2">
              <a href={phoneHref} class="group inline-flex items-center justify-center gap-3 bg-brand-red text-white text-base font-extrabold px-8 py-4 rounded-xl shadow-2xl shadow-brand-red/40 hover:brightness-110 transition-all duration-300 active:scale-[0.97]">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <span class="flex flex-col items-start leading-tight">
                  <span class="text-xs font-medium text-white/80">Call Now — Same-Day Service</span>
                  <span class="text-lg">{phone}</span>
                </span>
              </a>
              <a href="#request-form" class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur-sm border-2 border-white/20 text-white font-extrabold px-7 py-4 rounded-xl hover:bg-white/20 hover:border-white/30 transition-all duration-300 text-sm">
                Get Free Estimate
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
              </a>
            </div>

            <!-- Trust Strip -->
            <div class="flex flex-wrap items-center gap-x-6 gap-y-2 pt-2">
              <div class="flex items-center gap-2 text-white/70 text-xs font-semibold">
                <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
                <span>Licensed • Bonded • Insured</span>
              </div>
              <div class="flex items-center gap-2 text-white/70 text-xs font-semibold">
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <span>4.9★ Average Rating</span>
              </div>
              <div class="flex items-center gap-2 text-white/70 text-xs font-semibold">
                <span class="text-xs font-bold bg-white/10 px-2 py-0.5 rounded">CA Lic #1155955</span>
              </div>
              <div class="flex items-center gap-2 text-white/70 text-xs font-semibold">
                <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/></svg>
                <span>Financing Available</span>
              </div>
            </div>
          </div>

          <!-- RIGHT: Form -->
          <div id="request-form" class="lg:col-span-5 lg:sticky lg:top-28">
            <div class="relative">
              <div class="absolute -inset-1 bg-gradient-to-b from-brand-red/40 to-brand-blue/40 rounded-2xl blur-xl opacity-60"></div>
              <div class="relative">
                <LandingForm client:load />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== STATS STRIP ========== -->
    <section class="bg-white border-b border-slate-100 py-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
          {[
            { value: '10+', label: 'Years in Business', icon: 'M12 6v6l4 2' },
            { value: '5,000+', label: 'Happy Customers', icon: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z' },
            { value: '100%', label: 'Satisfaction Guarantee', icon: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
            { value: '4.9★', label: 'Google Rating', icon: 'M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z' },
          ].map((s) => (
            <div class="flex items-center gap-4 bg-slate-50 rounded-xl px-5 py-4 border border-slate-100">
              <div class="w-11 h-11 rounded-xl bg-brand-blue/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d={s.icon}/></svg>
              </div>
              <div>
                <div class="text-xl font-extrabold text-brand-blue">{s.value}</div>
                <div class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider">{s.label}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== FLEET IMAGE SPLIT ========== -->
    <section class="bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center py-12 sm:py-16">
          <div class="rounded-2xl overflow-hidden shadow-xl border border-slate-100">
            <Image src={teamImg} alt="HiLo HVAC fleet — fully loaded trucks ready for same-day AC repair and HVAC dispatch in Orange County" class="w-full h-[300px] sm:h-[400px] object-cover hover:scale-105 transition-transform duration-700" widths={[800, 600]} sizes="(max-width: 1024px) 100vw, 50vw" loading="lazy" />
          </div>
          <div class="space-y-5">
            <span class="inline-block text-[11px] font-extrabold text-brand-red uppercase tracking-[0.2em] bg-brand-red/10 px-4 py-1.5 rounded-full">Ready to Roll</span>
            <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-blue leading-tight">Fully Loaded Trucks. Same-Day HVAC Dispatch.</h2>
            <p class="text-slate-500 font-medium leading-relaxed">Our fleet of fully-stocked service vehicles is dispatched across <a href="#request-form" class="text-brand-blue underline hover:text-brand-red transition-colors font-bold">Orange County &amp; LA</a> every day. We carry the parts for most <a href="#request-form" class="text-brand-blue underline hover:text-brand-red transition-colors font-bold">AC repairs</a> and <a href="#request-form" class="text-brand-blue underline hover:text-brand-red transition-colors font-bold">heating service</a> — so we fix it right, the first time, without waiting on supplies.</p>
            <div class="flex flex-col sm:flex-row gap-3 pt-2">
              <a href={phoneHref} class="inline-flex items-center justify-center gap-2 bg-brand-red text-white font-extrabold px-6 py-3.5 rounded-xl hover:brightness-110 transition-all shadow-lg shadow-brand-red/30 active:scale-[0.98] text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                Call for Dispatch
              </a>
              <a href="#request-form" class="inline-flex items-center justify-center gap-2 bg-white text-brand-blue border-2 border-brand-blue/20 font-extrabold px-6 py-3.5 rounded-xl hover:bg-brand-blue/5 hover:border-brand-blue/40 transition-all text-sm">
                Schedule Service
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== SERVICES ========== -->
    <section class="pb-16 sm:pb-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto space-y-3 mb-12">
          <span class="inline-block text-[11px] font-extrabold text-brand-red uppercase tracking-[0.2em] bg-brand-red/10 px-4 py-1.5 rounded-full">What We Fix</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-blue leading-tight">Complete HVAC Solutions — One Call Does It All</h2>
          <p class="text-slate-500 font-medium text-sm"><a href="#request-form" class="text-brand-blue underline hover:text-brand-red transition-colors font-bold">AC repair</a>, <a href="#request-form" class="text-brand-blue underline hover:text-brand-red transition-colors font-bold">heating service</a>, <a href="#request-form" class="text-brand-blue underline hover:text-brand-red transition-colors font-bold">HVAC maintenance</a> &amp; more.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {services.map((svc) => (
            <div class="relative bg-white rounded-2xl border-2 border-slate-100 p-6 hover:border-brand-blue/30 hover:shadow-xl hover:shadow-brand-blue/5 transition-all duration-300 block">
              <div class="text-3xl mb-4">{svc.icon}</div>
              <h3 class="text-lg font-extrabold text-brand-blue mb-3">{svc.title}</h3>
              <ul class="space-y-2.5">
                {svc.features.map((f) => (
                  <li class="flex items-center gap-2.5 text-xs font-semibold text-slate-500">
                    <span class="w-1.5 h-1.5 rounded-full bg-brand-red flex-shrink-0"></span>
                    {f}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ========== HOW IT WORKS + TRUST ========== -->
    <section class="py-16 sm:py-20 bg-slate-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto space-y-3 mb-14">
          <span class="inline-block text-[11px] font-extrabold text-brand-red uppercase tracking-[0.2em] bg-brand-red/10 px-4 py-1.5 rounded-full">Simple Process</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-blue leading-tight">From Call to Cool Air — Fast</h2>
          <p class="text-slate-500 font-medium text-sm">No runaround. Here's exactly what happens when you reach out for <a href="#request-form" class="text-brand-blue underline hover:text-brand-red transition-colors font-bold">AC repair</a> or <a href="#request-form" class="text-brand-blue underline hover:text-brand-red transition-colors font-bold">emergency HVAC service</a>.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {[
            { step: '1', title: 'Call or Submit the Form', desc: 'A real dispatcher calls back within 15 minutes to confirm your appointment window.', color: 'bg-brand-red' },
            { step: '2', title: 'We Diagnose On-Site', desc: 'A certified technician arrives, inspects your system, and gives an upfront quote.', color: 'bg-brand-blue' },
            { step: '3', title: 'Same-Day Repair', desc: 'Once you approve, we get to work — most repairs completed the same visit.', color: 'bg-green-600' },
