---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTASection from '../../components/CTASection';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const faqSchemaObject = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What topics do you cover on your blog?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "HVAC tips, seasonal maintenance guides, energy efficiency advice, and common repair guides."
      }
    },
    {
      "@type": "Question",
      "name": "How often do you publish new articles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We regularly publish new content to help homeowners maintain their HVAC systems."
      }
    },
    {
      "@type": "Question",
      "name": "Can I suggest a blog topic?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely — contact us with your suggestion and we'll consider it for a future post."
      }
    }
  ]
};

const title = 'Blogs | HiLo Heating & Air';
const description = 'Expert HVAC advice, tips, and guides from the HiLo Heating and Air team. Learn about AC repair, heating maintenance, and indoor air quality.';
---

<BaseLayout title={title} description={description} faqSchema={faqSchemaObject}>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-brand-blue to-blue-800 py-20 sm:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">HVAC Blog</h1>
        <p class="text-white/80 text-lg max-w-2xl mx-auto">Expert HVAC advice, tips, and guides from the HiLo Heating and Air team.</p>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <article class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100">
              <a href={`/blogs/${post.id}/`} class="block">
                {post.data.image && (
                  <div class="aspect-[16/10] overflow-hidden">
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="p-6">
                  <div class="flex items-center gap-3 mb-3">
                    <span class="text-xs font-semibold text-brand-blue bg-brand-blue/10 px-3 py-1 rounded-full">{post.data.category}</span>
                    <time class="text-xs text-gray-400" datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                    </time>
                  </div>
                  <h2 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-brand-blue transition-colors line-clamp-2">{post.data.title}</h2>
                  <p class="text-gray-500 text-sm leading-relaxed line-clamp-3">{post.data.description}</p>
                  <div class="mt-4 flex items-center text-brand-blue text-sm font-semibold">
                    Read More
                    <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-20 bg-slate-50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">Have Questions?</h2>
        <p class="text-gray-500 mb-8">Call HiLo Heating and Air today for expert HVAC advice and service.</p>
        <a href="tel:+17148535534" class="inline-flex items-center gap-2 bg-brand-blue text-white font-bold px-8 py-4 rounded-lg hover:bg-blue-700 transition text-lg">
          (714) 853-5534
        </a>
      </div>
    </section>

    <CTASection client:visible />
  </main>
  <Footer />
</BaseLayout>
