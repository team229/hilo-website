---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection';
---

<BaseLayout title="Thank You | HiLo Heating & Air" description="Your HVAC service request has been received. Our dispatcher will call you within 15 minutes." robots="noindex, nofollow">
  <Header />
  <main>
    <section class="py-20 sm:py-28 bg-gradient-to-br from-brand-blue to-blue-800">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="w-20 h-20 rounded-full bg-white/20 flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">Thank You!</h1>
        <p class="text-white/80 text-lg max-w-xl mx-auto mb-8">Your request has been received. A dispatcher is reviewing it and will call you within 15 minutes.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/" class="inline-block bg-white text-brand-blue font-bold px-8 py-4 rounded-xl hover:bg-gray-100 transition">Back to Home</a>
          <a href="tel:+17148535534" class="inline-block bg-brand-red text-white font-bold px-8 py-4 rounded-xl hover:bg-red-700 transition">Call Now: (714) 853-5534</a>
        </div>
      </div>
    </section>
    <CTASection client:visible />
  </main>
  <Footer />
</BaseLayout>
