---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTASection from '../../components/CTASection';
---

<BaseLayout title="HVAC Maintenance, Inspection & Installation | HiLo Heating & Air" description="Explore complete HVAC maintenance services, system inspections, and new HVAC installation in Orange County. Same-day scheduling, upfront pricing, and EPA-certified technicians. Request a free estimate today!">
  <Header />
  <main>
    <section class="bg-gradient-to-br from-brand-blue to-blue-800 py-20 sm:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">Our HVAC Services</h1>
        <p class="text-white/80 text-lg max-w-2xl mx-auto">Complete HVAC maintenance, inspection, and installation services across Orange County. Same-day scheduling, upfront pricing, and EPA-certified technicians.</p>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {[
            { title: 'Air Conditioning Services', desc: 'Expert AC repair, installation, and maintenance.', href: '/services/air-conditioning-services/' },
            { title: 'Heating Services', desc: 'Reliable furnace repair, heating maintenance and installation.', href: '/services/heating-services/' },
            { title: 'HVAC Services', desc: 'Complete heating and cooling services for your home.', href: '/services/hvac-services/' },
            { title: 'Commercial HVAC', desc: 'HVAC services for offices, restaurants, and more.', href: '/services/commercial-hvac-services/' },
            { title: 'Indoor Air Quality', desc: 'Air purification, filtration, and humidity control.', href: '/services/indoor-air-quality-solutions/' },
          ].map((svc) => (
            <a href={svc.href} class="bg-white border border-brand-blue/10 rounded-2xl p-6 hover:shadow-lg hover:border-brand-blue/30 transition-all group">
              <h3 class="text-lg font-bold text-brand-blue mb-2 group-hover:text-brand-red transition-colors">{svc.title}</h3>
              <p class="text-sm text-slate-600 mb-4">{svc.desc}</p>
              <span class="text-sm font-semibold text-brand-blue group-hover:text-brand-red transition-colors inline-flex items-center gap-1">
                Learn More
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTASection client:visible />
  </main>
  <Footer />
</BaseLayout>
