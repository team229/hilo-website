---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection';
import { Image } from 'astro:assets';
import teamImg from '../assets/team.jpg';
---

<BaseLayout title="About Us | HiLo Heating & Air" description="Learn about HiLo Heating & Air — Orange County's trusted HVAC company since 2000. EPA-certified technicians, same-day service, and honest pricing for all your heating and cooling needs.">
  <Header />
  <main>
    {/* Hero */}
    <section class="bg-gradient-to-br from-brand-blue to-blue-800 py-20 sm:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">About HiLo Heating & Air</h1>
        <p class="text-white/80 text-lg max-w-2xl mx-auto">Family owned and operated, serving Orange County with reliable HVAC solutions since day one.</p>
      </div>
    </section>

    {/* Content */}
    <section class="py-16 sm:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <span class="inline-block bg-brand-red/10 text-brand-red text-sm font-semibold px-4 py-1.5 rounded-full mb-4">Our Story</span>
            <h2 class="text-3xl font-bold text-brand-blue mb-6">Orange County's Trusted HVAC Partner</h2>
            <p class="text-slate-600 leading-relaxed mb-4">
              HiLo Heating & Air Conditioning is a family-owned and operated HVAC company serving Orange County and surrounding areas. We specialize in providing reliable, same-day HVAC repair, installation, and maintenance services.
            </p>
            <p class="text-slate-600 leading-relaxed mb-4">
              Our team of EPA-certified technicians is fully insured and committed to delivering exceptional service. We believe in repairing before replacing, saving you money while ensuring your comfort.
            </p>
            <p class="text-slate-600 leading-relaxed mb-6">
              From emergency AC repairs to complete heating system installations, we handle it all with professionalism and care. We treat every home like our own.
            </p>
            <a href="tel:+17148535534" class="inline-block bg-brand-red text-white font-bold px-8 py-3.5 rounded-xl text-base hover:bg-red-700 transition shadow-lg shadow-brand-red/30">
              Call Us Today
            </a>
          </div>
          <div class="relative rounded-2xl overflow-hidden shadow-xl">
            <Image src={teamImg} alt="HiLo Team" class="w-full h-auto" widths={[800, 600]} sizes="(max-width: 1024px) 100vw, 50vw" />
          </div>
        </div>
      </div>
    </section>

    {/* Values */}
    <section class="py-16 sm:py-24 bg-brand-blue/5">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-brand-blue mb-4">Our Values</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            { icon: '🔧', title: 'Quality Work', desc: 'We take pride in every job, big or small.' },
            { icon: '💰', title: 'Honest Pricing', desc: 'Upfront pricing with no hidden fees.' },
            { icon: '⚡', title: 'Fast Response', desc: 'Same-day service when you need it most.' },
            { icon: '🤝', title: 'Customer First', desc: 'Your satisfaction is our top priority.' },
          ].map((v) => (
            <div key={v.title} class="bg-white rounded-2xl p-6 text-center shadow-sm">
              <div class="text-3xl mb-3">{v.icon}</div>
              <h3 class="text-lg font-bold text-brand-blue mb-2">{v.title}</h3>
              <p class="text-sm text-slate-600">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTASection client:visible />
  </main>
  <Footer />
</BaseLayout>
