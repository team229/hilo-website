---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTASection from '../../components/CTASection';
import Reviews from '../../components/Reviews';
import ServiceForm from '../../components/ServiceForm';
import LicenseBadges from '../../components/LicenseBadges.astro';
import BrandsSection from '../../components/BrandsSection.astro';

const faqSchemaObject = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do you handle coastal corrosion issues in Costa Mesa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — we regularly service HVAC systems affected by salt air corrosion in coastal Costa Mesa homes."
      }
    },
    {
      "@type": "Question",
      "name": "How fast is AC repair in Costa Mesa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Same-day service available. Most AC repairs in Costa Mesa are handled within hours of your call."
      }
    },
    {
      "@type": "Question",
      "name": "Do you serve all of Costa Mesa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — we cover Eastside, Westside, Mesa Verde, and all Costa Mesa neighborhoods."
      }
    }
  ]
};
---

<BaseLayout title="HVAC Services in Costa Mesa, CA | HiLo Heating & Air" description="Expert AC repair, heating service, and HVAC maintenance in Costa Mesa, CA. Fast, reliable service from licensed technicians at HiLo Heating & Air." faqSchema={faqSchemaObject}>
  <Header />
  <main>
    <section class="bg-gradient-to-br from-brand-blue to-blue-800 py-20 sm:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">Air Conditioning Repair Costa Mesa</h1>
        <p class="text-white/80 text-lg max-w-2xl mx-auto">Summer in Costa Mesa doesn't mess around, and neither does a broken AC unit at 2pm on a Tuesday. Hilo Heating and Air handles AC repair Costa Mesa residents have relied on for years.</p>
      </div>
    </section>

    <section class="py-10 pb-4 sm:py-16 sm:pb-6 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <LicenseBadges />
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-10 items-start">
          <div>
            <span class="inline-block bg-brand-blue/10 text-brand-blue text-sm font-semibold px-4 py-1.5 rounded-full mb-4">Schedule Service</span>
            <h2 class="text-3xl sm:text-4xl font-bold text-brand-blue mb-4">Get a Free Estimate</h2>
            <p class="text-slate-600 mb-6">Fill out the form and our team will get back to you within 15 minutes. Same-day service available.</p>
            <div class="space-y-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-brand-blue/10 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <span class="text-sm font-semibold text-brand-blue">Same-Day Service Available</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-brand-blue/10 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
                </div>
                <span class="text-sm font-semibold text-brand-blue">Free Diagnostics with Repair</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-brand-blue/10 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>
                </div>
                <span class="text-sm font-semibold text-brand-blue">Upfront Pricing, No Hidden Fees</span>
              </div>
            </div>
          </div>
          <ServiceForm client:load />
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 prose prose-lg">
        <h2 class="text-2xl sm:text-3xl font-bold text-brand-blue mt-0 mb-4">AC Repair Services in Costa Mesa</h2>

        <p>Summer in Costa Mesa doesn't mess around, and neither does a broken AC unit at 2pm on a Tuesday. If your system's blowing warm air or making a noise it definitely shouldn't be making, Hilo Heating and Air handles <strong>air conditioning repair Costa Mesa</strong> residents have relied on for years — not just the easy fixes, but the messy refrigerant leaks and dead compressors too.</p>

        <h2>What Makes Hilo Heating and Air Different</h2>
        <p>There's no shortage of HVAC companies in Orange County. What tends to set us apart is pretty simple: we show up when we say we will, we explain what's actually wrong before we touch anything, and we don't pad the bill. Our techs work on central air systems, ductless mini-splits, heat pumps — basically whatever's installed in your house, whoever made it. When someone calls about <strong>air conditioning repair Costa Mesa</strong> weather has finally broken, we'd rather walk them through the diagnosis than just hand over a number.</p>

        <h2>The Repairs We See Most Often</h2>
        <p>A lot of calls come down to the same handful of culprits — a blown capacitor, a coil caked in dust, a compressor on its last legs, or a unit that just won't kick on at all. Sometimes it's something smaller, like a thermostat that's lost its mind. Either way, that's the bread and butter of <strong>air conditioning repair Costa Mesa</strong> homeowners need most: short cycling, weak airflow, a sudden jump in the power bill. We'll also flag anything that looks like it's heading toward a bigger failure, because nobody wants to discover that on the hottest day of August.</p>

        <h2>We Don't Make You Wait a Week</h2>
        <p>Nobody wants to hear "we can fit you in next Thursday" when their house is 85 degrees. That's why same-day visits are the norm, not the exception, for <strong>air conditioning repair Costa Mesa</strong> residents request during the busy stretch of summer. Trucks go out stocked with the parts techs actually use, so most jobs wrap up in one trip instead of two.</p>

        <h2>Local, and It Shows</h2>
        <p>Being based here means we already know what Costa Mesa's coastal air and salt exposure tend to do to outdoor units over time — it's not something you pick up from a manual. Every <strong>air conditioning repair Costa Mesa</strong> job gets done to code, with parts and labor backed by a guarantee, because half the point of hiring local is trusting the people who'll actually be around if something comes up later.</p>
        <p>If your system's struggling, give Hilo Heating and Air a call — we'd rather fix it right the first time than see you again in two weeks.</p>
      </div>
    </section>

    

    <Reviews client:visible />
    <BrandsSection />

    <section class="py-16 sm:py-24 bg-slate-50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-brand-blue mb-8">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <div class="bg-white rounded-xl p-6 border border-brand-blue/10">
            <h3 class="text-lg font-bold text-brand-blue mb-2">How fast can someone get to my house?</h3>
            <p class="text-slate-600">Usually same-day, sometimes next-day if it's a slammed week — summer gets busy fast.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-brand-blue/10">
            <h3 class="text-lg font-bold text-brand-blue mb-2">My AC is running but not cooling. Is that a repair or a whole new system?</h3>
            <p class="text-slate-600">Most of the time it's repairable — low refrigerant, a dirty coil, a failing part. We'll diagnose it on-site before talking replacement.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-brand-blue/10">
            <h3 class="text-lg font-bold text-brand-blue mb-2">Do you only work on certain brands?</h3>
            <p class="text-slate-600">No — central air, mini-splits, heat pumps, most major brands. If it's installed in a Costa Mesa home, odds are we've worked on one like it.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-brand-blue/10">
            <h3 class="text-lg font-bold text-brand-blue mb-2">Will I know the cost before you start?</h3>
            <p class="text-slate-600">Yes. You'll get a price before any work begins, not a surprise on the invoice.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-brand-blue/10">
            <h3 class="text-lg font-bold text-brand-blue mb-2">How often should I get the system checked?</h3>
            <p class="text-slate-600">Once a year, ideally before it gets hot, catches small problems before they become emergency calls.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-brand-blue/10">
            <h3 class="text-lg font-bold text-brand-blue mb-2">Are your guys actually licensed?</h3>
            <p class="text-slate-600">Yes, every technician is licensed and insured.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-brand-blue/10">
            <h3 class="text-lg font-bold text-brand-blue mb-2">Do you cover areas outside Costa Mesa too?</h3>
            <p class="text-slate-600">We serve a good chunk of Orange County — just ask and we'll confirm your neighborhood.</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-brand-blue/10">
            <h3 class="text-lg font-bold text-brand-blue mb-2">What if the same problem comes back?</h3>
            <p class="text-slate-600">Repairs are backed by a guarantee, so that's covered.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-brand-blue/5 py-8">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-brand-blue font-semibold">Hilo Heating and Air · 8131 Electric Ave, Stanton, CA 90680, United States</p>
        <p class="text-slate-600 mt-1"><a href="tel:+17148535534" class="hover:text-brand-red transition">(714) 853-5534</a> · <a href="mailto:info@hiloheatingandair.com" class="hover:text-brand-red transition">info@hiloheatingandair.com</a></p>
      </div>
    </section>

    <CTASection client:visible />
  </main>
  <Footer />
</BaseLayout>
