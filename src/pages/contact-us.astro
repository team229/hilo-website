---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection';
import ServiceForm from '../components/ServiceForm';
import LicenseBadges from '../components/LicenseBadges.astro';

const faqSchemaObject = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How quickly do you respond to inquiries?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We typically respond within 15 minutes during business hours."
      }
    },
    {
      "@type": "Question",
      "name": "What information should I provide when contacting you?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your name, phone number, address, and a brief description of the issue."
      }
    },
    {
      "@type": "Question",
      "name": "Do you offer free estimates?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — free estimates and free diagnostics with any approved repair."
      }
    }
  ]
};
---

<BaseLayout title="Contact Us | HiLo Heating & Air" description="Contact HiLo Heating & Air for same-day HVAC service in Orange County. Call (714) 853-5534 for emergency AC repair, heating service, and free estimates." faqSchema={faqSchemaObject}>
  <Header />
  <main>
    {/* Hero */}
    <section class="bg-gradient-to-br from-brand-blue to-blue-800 py-20 sm:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">Contact Us</h1>
        <p class="text-white/80 text-lg max-w-2xl mx-auto">Ready to schedule service? Reach out to us today for a free estimate.</p>
      </div>
    </section>

    <LicenseBadges />

    {/* Contact Form & Info */}
    <section class="py-16 sm:py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          {/* Form */}
          <ServiceForm client:load />

          {/* Info */}
          <div class="space-y-8">
            <div>
              <h2 class="text-2xl font-bold text-brand-blue mb-6">Get in Touch</h2>
              <p class="text-slate-600 mb-8">We're here to help with all your HVAC needs. Reach out to us anytime.</p>
            </div>

            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-brand-blue/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <div>
                  <h3 class="font-bold text-brand-blue mb-1">Phone</h3>
                  <a href="tel:+17148535534" class="text-slate-600 hover:text-brand-red transition">(714) 853-5534</a>
                  <p class="text-sm text-brand-blue/60">24/7 Emergency Service</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-brand-blue/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </div>
                <div>
                  <h3 class="font-bold text-brand-blue mb-1">Email</h3>
                  <a href="mailto:info@hiloheatingandair.com" class="text-slate-600 hover:text-brand-red transition">info@hiloheatingandair.com</a>
                  <p class="text-sm text-brand-blue/60">We respond within 24 hours</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-brand-blue/10 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div>
                  <h3 class="font-bold text-brand-blue mb-1">Location</h3>
                  <p class="text-slate-600">8131 Electric Ave, Stanton, CA 90680</p>
                  <p class="text-sm text-brand-blue/60">Headquarters</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <CTASection client:visible />
  </main>
  <Footer />
</BaseLayout>
