---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection';

import AboutIntro from '../components/AboutIntro';
import TrustedChoiceSection from '../components/TrustedChoiceSection';
import ReliableService from '../components/ReliableService';
import ServiceCards from '../components/ServiceCards';
import CTABanner from '../components/CTABanner';
import ServiceAreas from '../components/ServiceAreas';
import Reviews from '../components/Reviews';
import BrandsSection from '../components/BrandsSection.astro';
import AboutStats from '../components/AboutStats';
import ContactBar from '../components/ContactBar';
import FAQSection from '../components/FAQSection';
import CTASection from '../components/CTASection';
---

<BaseLayout   title="AC Repair Anaheim | HiLo Heating & Air" description="Need AC repair in Anaheim? HiLo Heating & Air offers same-day AC repair, free diagnostics with repair, and 24/7 emergency service. EPA-certified technicians. Call (714) 853-5534!">
  <Header />
  <main>
    <HeroSection client:load />

    <!-- Services + Form Section -->
    <section class="bg-[#f3f7f9] py-16 sm:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

          <!-- Left Column: Main Services -->
          <div class="lg:col-span-7">
            <h2 class="text-3xl sm:text-4xl font-extrabold text-[#002d62] mb-2">Our HVAC Services</h2>
            <div class="w-16 h-1 bg-[#cc0000] mb-6"></div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <a href="/service/air-conditioning/" class="flex items-center space-x-3 bg-white rounded-xl p-4 shadow-[0_4px_12px_rgba(0,0,0,0.04)] border border-gray-100 hover:border-[#cc0000] hover:shadow-md transition-all duration-200 group">
                <div class="w-10 h-10 bg-[#cc0000]/10 rounded-lg flex items-center justify-center text-[#cc0000] flex-shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" strokeWidth="2" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
                </div>
                <span class="font-bold text-sm text-[#1e293b] group-hover:text-[#cc0000] transition-colors">Air Conditioning</span>
              </a>
              <a href="/service/heating/" class="flex items-center space-x-3 bg-white rounded-xl p-4 shadow-[0_4px_12px_rgba(0,0,0,0.04)] border border-gray-100 hover:border-[#cc0000] hover:shadow-md transition-all duration-200 group">
                <div class="w-10 h-10 bg-[#cc0000]/10 rounded-lg flex items-center justify-center text-[#cc0000] flex-shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" strokeWidth="2" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" /></svg>
                </div>
                <span class="font-bold text-sm text-[#1e293b] group-hover:text-[#cc0000] transition-colors">Heating</span>
              </a>
              <a href="/service/hvac-services/" class="flex items-center space-x-3 bg-white rounded-xl p-4 shadow-[0_4px_12px_rgba(0,0,0,0.04)] border border-gray-100 hover:border-[#cc0000] hover:shadow-md transition-all duration-200 group">
                <div class="w-10 h-10 bg-[#cc0000]/10 rounded-lg flex items-center justify-center text-[#cc0000] flex-shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" strokeWidth="2" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m8.25 3v6.75m0 0l-3-3m3 3l3-3M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>
                </div>
                <span class="font-bold text-sm text-[#1e293b] group-hover:text-[#cc0000] transition-colors">HVAC Services</span>
              </a>
              <a href="/service/indoor-air-quality/" class="flex items-center space-x-3 bg-white rounded-xl p-4 shadow-[0_4px_12px_rgba(0,0,0,0.04)] border border-gray-100 hover:border-[#cc0000] hover:shadow-md transition-all duration-200 group">
                <div class="w-10 h-10 bg-[#cc0000]/10 rounded-lg flex items-center justify-center text-[#cc0000] flex-shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" strokeWidth="2" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" /><path strokeLinecap="round" strokeLinejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                </div>
                <span class="font-bold text-sm text-[#1e293b] group-hover:text-[#cc0000] transition-colors">Indoor Air Quality</span>
              </a>
            </div>
          </div>

          <!-- Right Column: Form -->
          <div class="lg:col-span-5">
            <div class="bg-[#003366] rounded-2xl p-6 sm:p-8 shadow-[0_20px_50px_rgba(0,0,0,0.3)] border border-[#004080]">
              <h3 class="text-2xl sm:text-3xl font-extrabold text-white mb-2">Schedule Service</h3>
              <p class="text-xs sm:text-sm text-gray-200 mb-6 font-medium">Fast response for repairs, installations, and emergency service.</p>
              <form class="space-y-4">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400 pointer-events-none">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fillRule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clipRule="evenodd" /></svg>
                    </span>
                    <input type="text" placeholder="Full Name" class="w-full bg-white text-gray-900 placeholder-gray-400 pl-10 pr-4 py-3 rounded-lg border border-transparent focus:outline-none focus:ring-2 focus:ring-[#cc0000] text-sm font-semibold transition" />
                  </div>
                  <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400 pointer-events-none">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" /></svg>
                    </span>
                    <input type="tel" placeholder="Phone Number" class="w-full bg-white text-gray-900 placeholder-gray-400 pl-10 pr-4 py-3 rounded-lg border border-transparent focus:outline-none focus:ring-2 focus:ring-[#cc0000] text-sm font-semibold transition" />
                  </div>
                </div>
                <div class="relative">
                  <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400 pointer-events-none">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" /><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" /></svg>
                  </span>
                  <input type="email" placeholder="Email Address" class="w-full bg-white text-gray-900 placeholder-gray-400 pl-10 pr-4 py-3 rounded-lg border border-transparent focus:outline-none focus:ring-2 focus:ring-[#cc0000] text-sm font-semibold transition" />
                </div>
                <div class="relative">
                  <select class="w-full bg-white text-gray-900 pl-4 pr-10 py-3 rounded-lg border border-transparent appearance-none focus:outline-none focus:ring-2 focus:ring-[#cc0000] text-sm font-semibold transition">
                    <option value="" disabled selected class="text-gray-400">Tell us about your HVAC issue...</option>
                    <option value="ac-repair">AC Repair</option>
                    <option value="heating-service">Heating Service</option>
                    <option value="mini-split">Mini Split Installation</option>
                    <option value="emergency">Emergency Request</option>
                  </select>
                  <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-gray-500">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" strokeWidth="2.5" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M19 9l-7 7-7-7" /></svg>
                  </div>
                </div>
                <button type="submit" class="w-full bg-[#cc0000] hover:bg-[#b30000] text-white font-extrabold py-3.5 rounded-lg text-center tracking-wide text-base transition duration-200 shadow-md flex items-center justify-center space-x-2 mt-2">
                  <span>Request Service</span>
                  <svg class="w-4 h-4 stroke-current" fill="none" strokeWidth="2.5" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                </button>
              </form>
            </div>
          </div>

        </div>
      </div>
    </section>

    <AboutIntro client:visible />
    <TrustedChoiceSection client:visible />
    <ReliableService client:visible />
    <ServiceCards client:visible />
    <CTABanner client:visible />
    <ServiceAreas client:visible />
    <Reviews client:visible />
    <BrandsSection />
    <AboutStats client:visible />
    <ContactBar client:visible />
    <FAQSection client:visible />
    <CTASection client:visible />
  </main>
  <Footer />
</BaseLayout>
