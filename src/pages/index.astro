---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';

import AboutIntro from '../components/AboutIntro.astro';
import TrustedChoiceSection from '../components/TrustedChoiceSection';
import ReliableService from '../components/ReliableService.astro';
import ServiceCards from '../components/ServiceCards.astro';
import CTABanner from '../components/CTABanner';
import ServiceAreas from '../components/ServiceAreas';
import ReviewsAndFAQ from '../components/ReviewsAndFAQ';
import BrandsSection from '../components/BrandsSection.astro';
import AboutStats from '../components/AboutStats.astro';
import ContactBar from '../components/ContactBar';
import CTASection from '../components/CTASection';
---

<BaseLayout   title="AC Repair Anaheim | HiLo Heating & Air" description="Need AC repair in Anaheim? HiLo Heating & Air offers same-day AC repair, free diagnostics with repair, and 24/7 emergency service. EPA-certified technicians. Call (714) 853-5534!">
  <Header />
  <main>
    <HeroSection />
    <AboutIntro />
    <TrustedChoiceSection client:visible />
    <ReliableService />
    <ServiceCards />
    <CTABanner client:visible />
    <ServiceAreas client:visible />
    <ReviewsAndFAQ client:visible />
    <BrandsSection />
    <AboutStats />
    <ContactBar client:visible />
    <CTASection client:visible />
  </main>
  <Footer />
</BaseLayout>
