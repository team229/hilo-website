---
import { Image } from 'astro:assets';
import hiloAirConditioning from '../assets/hilo-air-conditioning.jpg';
import hvacMaintenance from '../assets/hvac-maintenance.jpg';
import hiloHvacServices from '../assets/hilo-hvac-services.jpg';
import serviceCardsHero from '../assets/service-cards-hero.png';
import teamImg from '../assets/team.jpg';

const services = [
  {
    title: 'Air Conditioning',
    description: 'Expert AC repair, installation, and maintenance to keep your home cool and comfortable all year long.',
    icon: 'ac',
    link: '/service/air-conditioning/',
  },
  {
    title: 'Heating',
    description: 'Reliable furnace repair, heater installation, and heating maintenance for cozy winters.',
    icon: 'heating',
    link: '/service/heating/',
  },
  {
    title: 'HVAC Maintenance',
    description: 'Preventative tune-ups and inspections to extend system life and maximize energy efficiency.',
    icon: 'maintenance',
    link: '/service/hvac-services/',
  },
  {
    title: 'Indoor Air Quality',
    description: 'Air purification, filtration, and humidity control solutions for healthier indoor environments.',
    icon: 'air',
    link: '/service/indoor-air-quality/',
  },
];
---

<section class="relative bg-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <span class="inline-block bg-[#cc0000]/10 text-[#cc0000] text-sm font-semibold px-4 py-1.5 rounded-full mb-6 uppercase tracking-wide">HVAC Services</span>
        <h2 class="text-4xl sm:text-5xl font-bold text-[#002d62] leading-tight mb-2">
          Complete Heating &<br />
          Cooling <span class="text-[#cc0000]">Solutions</span>
        </h2>
        <div class="w-16 h-1 bg-[#cc0000] mb-6"></div>
        <p class="text-slate-600 text-lg leading-relaxed mb-8">
          Professional repair, maintenance, and installation services designed to keep your home comfortable year-round across our local service areas.
        </p>
      </div>
      <div class="relative">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl">
          <Image
            src={serviceCardsHero}
            alt="HiLo HVAC technician servicing air conditioning unit"
            class="w-full h-[350px] sm:h-[400px] lg:h-[500px] object-cover object-center"
            widths={[800, 600]}
            sizes="(max-width: 1024px) 100vw, 50vw"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-12">
      {services.map((svc) => (
        <a href={svc.link} class="group bg-white border border-slate-200 rounded-2xl p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="w-14 h-14 bg-[#cc0000]/10 rounded-xl flex items-center justify-center text-[#cc0000] mb-5 group-hover:bg-[#cc0000] group-hover:text-white transition-colors">
            {svc.icon === 'ac' && (
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
              </svg>
            )}
            {svc.icon === 'heating' && (
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z" />
              </svg>
            )}
            {svc.icon === 'maintenance' && (
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.66 5.66a2.12 2.12 0 01-3-3l5.66-5.66m3 3l3.54-3.54a2.12 2.12 0 013 3L14.42 18.17m-3-3l3-3m-3 3l-3 3m3-3l3-3" />
              </svg>
            )}
            {svc.icon === 'air' && (
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              </svg>
            )}
          </div>
          <h3 class="text-xl font-bold text-[#002d62] mb-3">{svc.title}</h3>
          <p class="text-slate-600 leading-relaxed mb-4">{svc.description}</p>
          <span class="inline-flex items-center text-[#cc0000] font-semibold group-hover:text-[#cc0000]/80 transition-colors">
            Learn More
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
