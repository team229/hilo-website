---
const brands = [
  { name: 'Carrier', logo: '/images/brands/carrier-logo.png' },
  { name: 'Goodman', logo: '/images/brands/goodman-logo.png' },
  { name: 'Daikin', logo: '/images/brands/daikin-logo.png' },
  { name: 'Trane', logo: '/images/brands/trane-logo.png' },
  { name: 'Lennox', logo: '/images/brands/lennox-logo.svg' },
  { name: 'Rheem', logo: '/images/brands/rheem-logo.svg' },
];
---

<section class="py-16 sm:py-24 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="inline-block bg-brand-blue/10 text-brand-blue text-sm font-semibold px-4 py-1.5 rounded-full mb-4">Trusted Brands</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-brand-blue mb-4">Brands We Service</h2>
      <p class="text-slate-600 max-w-2xl mx-auto">Our technicians are trained on all major HVAC brands.</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8 items-center">
      {brands.map((brand) => (
        <div class="flex items-center justify-center p-6 bg-white rounded-xl border border-slate-100 hover:border-brand-blue/20 hover:shadow-lg transition-all duration-300 group">
          <img 
            src={brand.logo} 
            alt={brand.name} 
            class="h-12 w-auto object-contain opacity-70 group-hover:opacity-100 transition-opacity duration-300"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
