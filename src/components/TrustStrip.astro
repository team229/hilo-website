---
const items = [
  {
    icon: 'ShieldCheck',
    title: 'Licensed & Insured',
    subtitle: 'CA Lic. #1155955',
  },
  {
    icon: 'Zap',
    title: 'Same-Day Service',
    subtitle: 'Fast response when you need it',
  },
  {
    icon: 'Heart',
    title: 'Family-Owned & Operated',
    subtitle: 'Proudly serving our community',
  },
  {
    icon: 'MapPin',
    title: 'Serving Orange County & Los Angeles',
    subtitle: 'Local experts you can trust',
  },
  {
    icon: 'Star',
    title: '100% Satisfaction Guarantee',
    subtitle: 'Your comfort is our priority',
  },
];
---

<section class="bg-white py-5 sm:py-7 border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 sm:gap-6">
      {
        items.map((item) => (
          <div class="flex items-center gap-3 text-[#002d62]">
            <div class="flex-shrink-0 w-9 h-9 rounded-full bg-[#002d62]/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-[#002d62]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                {
                  item.icon === 'ShieldCheck' && (
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  )
                }
                {
                  item.icon === 'Zap' && (
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  )
                }
                {
                  item.icon === 'Heart' && (
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                  )
                }
                {
                  item.icon === 'MapPin' && (
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  )
                }
                {
                  item.icon === 'Star' && (
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                  )
                }
              </svg>
            </div>
            <div>
              <span class="block text-sm font-extrabold leading-tight">{item.title}</span>
              <span class="block text-[11px] text-[#002d62]/70 font-medium mt-0.5">{item.subtitle}</span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
