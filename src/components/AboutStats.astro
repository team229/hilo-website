---
import { Image } from 'astro:assets';
import hiloHvacServices from '../assets/hilo-hvac-services.jpg';

const stats = [
  { value: '10+', label: 'Years of Experience' },
  { value: '5K+', label: 'Satisfied Customers' },
  { value: '100%', label: 'Commitment to Quality' },
];
---

<section class="py-16 sm:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-6 flex justify-center relative">
        <div class="relative w-full max-w-md rounded-2xl overflow-hidden shadow-2xl border-4 border-brand-blue/10">
          <Image src={hiloHvacServices} alt="HiLo HVAC Experts Team" class="w-full h-auto block" widths={[600, 400]} sizes="(max-width: 1024px) 100vw, 50vw" loading="lazy" />
          <div class="absolute bottom-4 left-4 right-4 sm:bottom-8 sm:left-8 sm:right-8 bg-white border border-brand-blue/10 rounded-xl p-3 sm:p-5 shadow-lg flex items-center gap-3 sm:gap-4">
            <div class="w-12 h-12 rounded-full bg-brand-red flex items-center justify-center text-white font-black text-lg shadow-md flex-shrink-0 animate-pulse">OK</div>
            <div>
              <p class="text-xs font-black uppercase text-brand-red tracking-wider">Approved Partner</p>
              <span class="text-[10px] text-brand-blue font-semibold block mt-0.5">Top-rated home comfort provider in Southern California.</span>
            </div>
          </div>
        </div>
      </div>
      <div class="lg:col-span-6 space-y-6">
        <div>
          <span class="text-xs font-bold text-brand-red uppercase tracking-wider block mb-1">About Us</span>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-blue leading-tight uppercase">
            Expert Solutions.<br />
            <span class="text-brand-red">Year After Year.</span>
          </h2>
        </div>
        <div class="w-16 h-1 bg-brand-red rounded"></div>
        <p class="text-sm text-slate-600 font-medium leading-relaxed">
          With over a decade of hands-on expertise, our team provides seamless system updates, prompt repairs, and verified cooling operations designed to withstand the hottest summer months.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 pt-2">
          {stats.map((s) => (
            <div class="bg-brand-blue/5 border border-brand-blue/10 rounded-xl p-4 text-center flex flex-col items-center justify-center">
              <div class="text-2xl font-extrabold text-brand-red">{s.value}</div>
              <div class="text-[10px] font-bold text-slate-600 uppercase tracking-widest mt-1">{s.label}</div>
            </div>
          ))}
        </div>
        <div class="bg-white border-2 border-brand-blue/10 text-brand-blue p-5 rounded-xl shadow-lg flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
          <div>
            <span class="text-[10px] font-bold uppercase tracking-widest text-brand-red">2026 Milestone</span>
            <p class="text-lg font-bold leading-tight">Another Great Year!</p>
            <p class="text-xs text-slate-600 font-medium mt-0.5">Voted the best customer-centric service team.</p>
          </div>
          <a href="#schedule-service" class="bg-brand-red text-white text-xs font-extrabold px-6 py-4 rounded-lg uppercase tracking-wider shadow-lg hover:bg-brand-blue transition-colors flex-shrink-0">Book Us Now</a>
        </div>
      </div>
    </div>
  </div>
</section>
