---
import { Image } from 'astro:assets';
import hvacMaintenance from '../assets/hvac-maintenance.jpg';

const checks = [
  '10+ years in business',
  'Same-Day service',
  'Family-owned values',
  '100% Satisfaction Focus',
];
---

<section class="py-16 sm:py-24 bg-white border-y border-brand-blue/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7 space-y-6">
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-brand-blue leading-tight uppercase">
          Exceptional Air Conditioning<br class="hidden sm:inline" />
          &amp; Heating Service<br />
          <span class="text-brand-red">With Integrity</span>
        </h2>
        <div class="w-20 h-1.5 bg-brand-red rounded"></div>
        <p class="text-xs sm:text-sm font-extrabold tracking-widest text-brand-blue/60 uppercase">
          Serving Anaheim and Orange County, HiLo Heating &amp; Air offers repair, maintenance, and installation for home HVAC systems.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-2">
          {checks.map((item) => (
            <div class="flex items-center gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-red/10 flex items-center justify-center text-brand-red flex-shrink-0">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              </span>
              <span class="font-bold text-sm text-brand-blue">{item}</span>
            </div>
          ))}
        </div>
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a href="/about-us/" class="bg-brand-red text-white text-center font-bold px-7 py-4 rounded hover:bg-brand-blue transition-colors uppercase tracking-wider text-xs">About Us</a>
          <a href="#reviews" class="border-2 border-brand-blue text-brand-blue text-center font-bold px-7 py-4 rounded hover:bg-brand-blue hover:text-white transition-all uppercase tracking-wider text-xs">Read Our Reviews</a>
        </div>
      </div>
      <div class="lg:col-span-5 flex justify-center">
        <div class="relative w-full max-w-sm aspect-square">
          <div class="absolute inset-0 bg-brand-red clip-hexagon transform scale-105"></div>
          <div class="absolute inset-0 bg-white clip-hexagon transform scale-[1.02]"></div>
          <div class="absolute inset-0 bg-brand-blue clip-hexagon overflow-hidden shadow-xl">
            <Image src={hvacMaintenance} alt="HiLo AC Technician" class="object-cover w-full h-full brightness-95 hover:scale-110 transition-transform duration-500" widths={[400, 300]} sizes="300px" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
