---
const locations = [
  'Anaheim', 'Costa Mesa', 'Fullerton', 'Garden Grove', 'Irvine',
  'Laguna Hills', 'Los Angeles', 'Newport Beach', 'Orange',
  'Orange County', 'Rancho Santa Margarita', 'Santa Ana', 'Stanton',
];
---

<section class="bg-[#f3f7f9] border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="text-center mb-10">
      <span class="text-[#cc0000] font-extrabold tracking-wider text-sm uppercase mb-2 block">Local HVAC Company</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-[#002d62] leading-tight">
        Proudly Serving <span class="text-[#cc0000]">Orange County & Los Angeles</span>
      </h2>
      <div class="w-16 h-1 bg-[#cc0000] rounded mx-auto mt-4 mb-4"></div>
      <p class="text-gray-600 max-w-xl mx-auto font-medium">
        We dispatch technicians daily across our service area to ensure your emergency repair needs are met promptly.
      </p>
    </div>
    <div class="flex flex-wrap justify-center gap-x-8 gap-y-3 max-w-3xl mx-auto">
      {locations.map((loc) => (
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#cc0000] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
          <span class="text-sm font-bold text-[#002d62]">{loc}</span>
        </div>
      ))}
    </div>
  </div>
</section>
