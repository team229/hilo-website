---
const features = [
  {
    title: 'Locally Owned & Operated',
    desc: 'We live and work in your community.',
    icon: 'location',
  },
  {
    title: 'Fast Response Times',
    desc: 'Local technicians ready when you need us most.',
    icon: 'clock',
  },
  {
    title: 'Licensed & Insured',
    desc: 'CA Lic. #1155955 Fully licensed and insured.',
    icon: 'shield',
  },
  {
    title: 'Upfront Pricing',
    desc: 'Honest, transparent pricing with no surprises.',
    icon: 'tag',
  },
  {
    title: 'Satisfaction Guaranteed',
    desc: '100% satisfaction on every service we provide.',
    icon: 'star',
  },
];
---

<section class="bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start mb-12">
      <div>
        <span class="text-xs font-bold text-brand-red uppercase tracking-widest">SERVICE AREAS</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold mt-3 leading-tight">
          <span class="text-brand-blue">Proudly Serving</span>
          <br />
          <span class="text-brand-red">Orange County &</span>
          <br />
          <span class="text-brand-red">Los Angeles</span>
        </h2>
        <div class="w-20 h-1.5 bg-brand-red rounded mt-5 mb-6"></div>
        <p class="text-slate-600 text-base leading-relaxed max-w-md mb-6">
          Our technicians are based locally and dispatch daily across our service area to ensure fast response times.
        </p>

        <div class="flex flex-wrap gap-x-6 gap-y-2 mb-8">
          {
            [
              { name: 'Anaheim', slug: 'anaheim' },
              { name: 'Costa Mesa', slug: 'costa-mesa' },
              { name: 'Fullerton', slug: '' },
              { name: 'Garden Grove', slug: 'garden-grove' },
              { name: 'Irvine', slug: 'irvine' },
              { name: 'Laguna Hills', slug: 'laguna-hills' },
              { name: 'Los Angeles', slug: 'los-angeles' },
              { name: 'Newport Beach', slug: 'newport-beach' },
              { name: 'Orange', slug: 'orange' },
              { name: 'Orange County', slug: 'orange-county' },
              { name: 'Rancho Santa Margarita', slug: 'rancho-santa-margarita' },
              { name: 'Santa Ana', slug: 'santa-ana' },
              { name: 'Stanton', slug: 'stanton' },
            ].map((loc) => (
              loc.slug
                ? <a href={`/service-areas/${loc.slug}/`} class="flex items-center gap-1.5 group">
                    <svg class="w-3.5 h-3.5 text-brand-red flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                    </svg>
                    <span class="text-sm font-bold text-brand-blue group-hover:text-brand-red transition-colors">{loc.name}</span>
                  </a>
                : <div class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-brand-red flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                    </svg>
                    <span class="text-sm font-bold text-brand-blue">{loc.name}</span>
                  </div>
            ))
          }
        </div>

        <div class="inline-flex items-center gap-4 bg-white border border-gray-200 rounded-xl p-4 shadow-sm">
          <div class="text-4xl font-bold text-blue-500">G</div>
          <div>
            <div class="flex items-center gap-2">
              <span class="text-2xl font-bold text-gray-900">5.0</span>
              <div class="flex text-yellow-400 gap-0.5">
                {[...Array(5)].map((_, i) => (
                  <svg key={i} class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                ))}
              </div>
              <span class="text-sm text-gray-500">(6)</span>
            </div>
            <span class="text-xs text-gray-500 block mt-0.5">Verified by Google</span>
          </div>
        </div>
      </div>

      <div class="relative rounded-2xl overflow-hidden shadow-xl border border-gray-200 h-[400px] lg:h-[450px]">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d664037.4755449896!2d-118.15!3d33.78!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80dc2763ac8378a9%3A0x4db1b0c8c4c0c0e0!2sOrange%20County%2C%20CA!5e0!3m2!1sen!2sus!4v1700000000000"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="HiLo Service Areas - Orange County & Los Angeles"
        ></iframe>
        <div class="absolute bottom-4 left-4 bg-white/95 backdrop-blur-sm rounded-lg px-3 py-2 shadow-lg flex items-center gap-2">
          <div class="w-4 h-4 rounded bg-pink-200 border border-pink-300"></div>
          <span class="text-xs font-semibold text-gray-700">Our Service Area</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 lg:gap-6">
      {features.map((f, i) => (
        <div key={i} class="bg-gray-50 border border-gray-100 rounded-xl p-5 text-center">
          <div class="w-12 h-12 rounded-full bg-brand-red/10 flex items-center justify-center mx-auto mb-3">
            {f.icon === 'location' && (
              <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            )}
            {f.icon === 'clock' && (
              <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            )}
            {f.icon === 'shield' && (
              <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              </svg>
            )}
            {f.icon === 'tag' && (
              <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
              </svg>
            )}
            {f.icon === 'star' && (
              <svg class="w-6 h-6 text-brand-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
              </svg>
            )}
          </div>
          <h3 class="text-sm font-bold text-gray-900 mb-1">{f.title}</h3>
          <p class="text-xs text-gray-500 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>
