---
const locations = [
  'Anaheim', 'Costa Mesa', 'Fullerton', 'Garden Grove', 'Irvine',
  'Laguna Hills', 'Los Angeles', 'Newport Beach', 'Orange',
  'Orange County', 'Rancho Santa Margarita', 'Santa Ana', 'Stanton',
];
---

<section class="bg-white border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div>
        <span class="text-[#cc0000] font-extrabold tracking-wider text-sm uppercase mb-3 block">Local HVAC Company</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-[#002d62] leading-[1.15] mb-4">
          Proudly Serving<br />
          <span class="text-[#cc0000]">Orange County &</span><br />
          <span class="text-[#cc0000]">Los Angeles</span>
        </h2>
        <div class="w-16 h-1 bg-[#cc0000] mb-6"></div>
        <p class="text-base text-gray-600 max-w-md mb-8 font-medium leading-relaxed">
          We dispatch technicians daily across our service area to ensure your emergency repair needs are met promptly.
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-3">
          {locations.map((loc) => (
            <div key={loc} class="flex items-center gap-2">
              <svg class="w-4 h-4 text-[#cc0000] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              <span class="text-sm font-bold text-[#002d62]">{loc}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="relative rounded-2xl overflow-hidden shadow-xl min-h-[400px]">
        <img
          src="/images/team.jpg"
          alt="HiLo Heating & Air service van and technician"
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
      </div>
    </div>
  </div>
</section>
