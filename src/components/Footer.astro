---

<footer class="bg-gray-950 font-montserrat text-slate-400 w-full">
  <div class="h-1.5 bg-brand-red w-full"></div>
  
  <div class="py-16 px-10 w-full">
    <div class="w-full flex flex-wrap justify-between gap-8">
      <div class="flex-[1.5] min-w-[260px]">
        <a href="/">
          <img src="/images/header-logo.png" alt="HiLo Heating & Air" class="h-[65px] w-auto rounded-lg inline-block mb-5" width="200" height="150" loading="lazy" />
        </a>
        <p class="text-sm leading-relaxed text-slate-400 mb-5">
          Expert Heating & Air Conditioning repair, installation, and maintenance in Anaheim and Orange County. We prioritize repair over replacements to save your money.
        </p>
        <div class="flex gap-3">
          {socials.map((social) => (
            <a href={social.href} target="_blank" rel="noopener noreferrer" title={social.name}
               class="w-9 h-9 bg-slate-700 text-white rounded-full flex items-center justify-center hover:bg-brand-blue hover:-translate-y-0.5 transition-all">
              <svg class="w-[18px] h-[18px] fill-current" viewBox="0 0 24 24"><path d={social.icon}/></svg>
            </a>
          ))}
        </div>
      </div>

      <div class="flex-1 min-w-[220px]">
        <h4 class="text-white text-base font-bold mb-6">Services</h4>
        <ul class="space-y-3">
          {serviceLinks.map((link) => (
            <li><a href={link.href} class="text-slate-400 text-sm hover:text-brand-red transition">{link.name}</a></li>
          ))}
        </ul>
      </div>

      <div class="flex-1 min-w-[220px]">
        <h4 class="text-white text-base font-bold mb-6">Service Areas</h4>
        <ul class="grid grid-cols-2 gap-x-4 gap-y-3">
          {areaLinks.map((link) => (
            <li><a href={link.href} class="text-slate-400 text-sm hover:text-brand-red transition">{link.name}</a></li>
          ))}
        </ul>
      </div>

      <div class="flex-1 min-w-[220px]">
        <h4 class="text-white text-base font-bold mb-6">Contact Info</h4>
        <div class="flex flex-col gap-5">
          <div class="flex items-start gap-3">
            <svg class="w-[18px] h-[18px] text-brand-red flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <div>
              <div class="text-white font-semibold text-sm"><a href="tel:+17148535534" class="hover:text-brand-red transition">(714) 853-5534</a></div>
              <div class="text-xs text-slate-400 mt-0.5">24/7 Emergency Service</div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-[18px] h-[18px] text-brand-red flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            <div>
              <div class="text-white font-semibold text-sm"><a href="mailto:info@hiloheatingandair.com" class="hover:text-brand-red transition">Email Us</a></div>
              <div class="text-xs text-slate-400 mt-0.5">info@hiloheatingandair.com</div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-[18px] h-[18px] text-brand-red flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <div>
              <div class="text-white font-semibold text-sm">Headquarters</div>
              <div class="text-xs text-slate-400 mt-0.5">8131, Electric Ave Stanton, CA 90680</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-slate-700 py-6 px-10 w-full">
    <div class="w-full flex justify-between items-center flex-wrap gap-4">
      <div class="text-xs text-slate-400">&copy; 2026 HiLo Heating & Air. All rights reserved.</div>
      <div class="flex gap-5">
        <a href="#" class="text-slate-400 text-xs hover:text-brand-red transition">Privacy Policy</a>
        <a href="#" class="text-slate-400 text-xs hover:text-brand-red transition">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
